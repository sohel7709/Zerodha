{
  "expo": {
    "name": "Zerodha Kite",
    "slug": "zerodha-kite",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zerodha.kite",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow Zerodha Kite to use the camera to scan KYC documents and capture your profile photo.",
        "NSPhotoLibraryUsageDescription": "Allow Zerodha Kite to access your photos to upload KYC documents and your profile photo.",
        "NSPhotoLibraryAddUsageDescription": "Allow Zerodha Kite to save downloaded statements and reports to your photo library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.zerodha.kite",
      "versionCode": 1,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECEIVE_SMS",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.READ_MEDIA_VIDEO"
      ]
    },
    "sdkVersion": "54.0.0",
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Zerodha Kite to use the camera to scan KYC documents and capture your profile photo."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Zerodha Kite to access your photos to upload KYC documents and your profile photo."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Zerodha Kite to access your media to upload and save statements.",
          "savePhotosPermission": "Allow Zerodha Kite to save downloaded statements and reports.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      "expo-notifications",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "f83a41b9-d1f9-4f56-8f0f-fea76d8c078f"
      }
    },
    "owner": "sohel9730",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/f83a41b9-d1f9-4f56-8f0f-fea76d8c078f"
    }
  }
}
